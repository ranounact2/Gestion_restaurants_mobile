{
  "name": "restaurant-app",
  "version": "1.0.0",
  "description": "Complete restaurant mobile app with React Native and Node.js backend",
  "private": true,
  "workspaces": [
    "app",
    "api"
  ],
  "scripts": {
    "dev": "concurrently \"npm run api:dev\" \"npm run app:start\"",
    "api:dev": "cd api && npm run dev",
    "app:start": "cd app && npm start",
    "app:build": "cd app && npm run build",
    "api:build": "cd api && npm run build",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "install:all": "npm install && cd app && npm install && cd ../api && npm install"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "concurrently": "^8.2.2",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.9.2"
  }
}
